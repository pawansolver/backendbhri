{
  "name": "bhri-backend",
  "version": "1.0.0",
  "description": "BHRI Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "kill-port": "powershell -Command \"$p = Get-NetTCPConnection -LocalPort 5000 -State Listen -EA 0 | Select -Expand OwningProcess -Unique; if ($p) { $p | ForEach { Stop-Process -Id $_ -Force -EA 0 } }\"",
    "dev": "npm run kill-port & nodemon server.js"
  },
