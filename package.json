    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.0.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sequelize": "^6.30.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
